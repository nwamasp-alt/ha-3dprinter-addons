#!/usr/bin/with-contenv bashio

SAFE_MODE=$(bashio::config 'safe_mode')

# Argumentos base
ARGS="--basedir /data/.octoprint --host 0.0.0.0 --port 80 --iknowwhatimdoing"

# Se o Safe Mode estiver ligado, ele ignora os plugins lentos (OctoEverywhere, etc)
if bashio::var.true "${SAFE_MODE}"; then
    bashio::log.warning "Starting in SAFE MODE! Third-party plugins are disabled."
    ARGS="${ARGS} --safe"
fi

# FORÇAR PORTA 80 E CONFIANÇA NO PROXY DO HA
export OCTOPRINT_SERVER_PORT=80
export OCTOPRINT_REVERSE_PROXY_TRUST_ADDRESSES="127.0.0.1,::1,172.30.32.1/23"
export OCTOPRINT_SERVER_REVERSE_PROXY_HEADER_ENFORCE="true"

# AJUSTE PARA O PYTHON 3.13 (EVITAR O TIMEOUT DO S6)
export S6_CMD_WAIT_FOR_SERVICES_MAXTIME=0

bashio::log.info "Starting OctoPrint 1.11.7 on port 80..."

exec octoprint serve ${ARGS}
