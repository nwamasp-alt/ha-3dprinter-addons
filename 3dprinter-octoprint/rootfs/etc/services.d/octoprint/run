#!/usr/bin/with-contenv bashio

SAFE_MODE=$(bashio::config 'safe_mode')

# --- LIMPEZA RADICAL DA CONFIGURAÇÃO ---
# Isto garante que o OctoPrint ignora qualquer lixo de portas antigas
# e assume o Ingress do Home Assistant como a base correta.
OCTO_CONFIG="/data/.octoprint/config.yaml"

if [ -f "$OCTO_CONFIG" ]; then
    bashio::log.info "Ajustando portas no config.yaml..."
    # Remove qualquer menção a porta 5000 no ficheiro todo
    sed -i 's/port: 5000/port: 80/g' "$OCTO_CONFIG"
    # Garante que a descoberta de porta externa não estrague o Ingress
    sed -i 's/baseAddress:.*/baseAddress: http:\/\/127.0.0.1:80/g' "$OCTO_CONFIG"
fi

ARGS="--basedir /data/.octoprint --host 0.0.0.0 --port 80 --iknowwhatimdoing"

if bashio::var.true "${SAFE_MODE}"; then
    bashio::log.warning "Modo de Segurança ATIVO!"
    ARGS="${ARGS} --safe"
fi

# Variáveis para enganar o motor de cache do OctoPrint
export OCTOPRINT_SERVER_PORT=80
export OCTOPRINT_REVERSE_PROXY_TRUST_ADDRESSES="127.0.0.1,::1,172.30.32.1/23"

bashio::log.info "A lançar OctoPrint na porta 80..."

exec octoprint serve ${ARGS}
