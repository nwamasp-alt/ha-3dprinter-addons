#!/usr/bin/with-contenv bashio

SAFE_MODE=$(bashio::config 'safe_mode')

# Forçar a porta 80 no ficheiro de config (garantia extra)
if [ -f "/data/.octoprint/config.yaml" ]; then
    sed -i 's/port: [0-9]*/port: 80/g' /data/.octoprint/config.yaml
fi

# --- OVERRIDES DE AMBIENTE ---
# Estas variáveis têm prioridade sobre o config.yaml
export OCTOPRINT_SERVER_PORT=80
export OCTOPRINT_SERVER_HOST=0.0.0.0
# Força o OctoPrint a entender que está atrás do proxy do HA
export OCTOPRINT_SERVER_REVERSE_PROXY_HEADER_ENFORCE="true"
export OCTOPRINT_SERVER_REVERSE_PROXY_TRUST_ADDRESSES="127.0.0.1,::1,172.30.32.1/23"

ARGS="--basedir /data/.octoprint --host 0.0.0.0 --port 80 --iknowwhatimdoing"

if bashio::var.true "${SAFE_MODE}"; then
    bashio::log.warning "Modo de Segurança ATIVO!"
    ARGS="${ARGS} --safe"
fi

bashio::log.info "A lançar OctoPrint com overrides de porta 80..."

exec octoprint serve ${ARGS}
